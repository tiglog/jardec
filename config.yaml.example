## Path to the jadx executable used for the initial full-JAR decompilation pass.
#jadx_path: /path/to/jadx
#
## Path to the Procyon jar used for per-class fallback retries.
## jardec invokes it as: java -jar <procyon_path> -o <outputdir> --classpath <cp> <class>
#procyon_path: /path/to/procyon.jar
#
## Default dependency jars or directories for decompilation and patch-sources.
## Both `decompile` and `patch-sources` share this classpath:
## input JAR -> decompile_classpath -> CLI --classpath entries
##
## Relative paths are resolved from the directory containing this config file.
## Directory entries are expanded non-recursively to direct child *.jar files in sorted order.
## Empty directories are rejected as invalid classpath entries.
#decompile_classpath:
#  - libs
#  - third_party/extra.jar
#
## Path to the javac executable used by patch-sources.
#javac_path: /path/to/javac
#
## Default number of concurrent Procyon retry workers when --retry-concurrency is not provided.
default_retry_concurrency: 4
